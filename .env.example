# Copy this file to .env.local for local development.
# None of these are required to run the app — you can also paste a fal.ai
# key directly into the in-app Settings panel (gear icon in the header).

# Used only in local dev (npm run dev) as a fallback fal.ai key when no
# key is saved in Settings. Never used in production builds.
VITE_FAL_KEY=

# Server-side fal.ai key used by the /api/fal proxy (api/fal/proxy.ts).
# Required on Vercel if you want generation to work for users who have NOT
# saved their own key in Settings. Set this in the Vercel project's
# Environment Variables — it is not read from this file in production.
FAL_KEY=

# Vercel Blob read/write token, used by /api/blob/* routes to persist
# generations to the cloud gallery. Provisioned automatically when you
# add the Vercel Blob storage integration to your project.
BLOB_READ_WRITE_TOKEN=
